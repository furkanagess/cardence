# Railway — Cardence API environment variables
# Set these on the cardence API service (Root Directory: backend).
#
# PostgreSQL must be added as a separate Railway service first.
# See docs/deployment-cardenceapi.app.md → "PostgreSQL (Railway)".

# Required
ASPNETCORE_ENVIRONMENT=Production
Jwt__SigningKey=CHANGE-ME-MIN-32-CHARS-RANDOM-SECRET
Api__PublicBaseUrl=https://cardenceapi.app
AllowedHosts=cardenceapi.app;www.cardenceapi.app;healthcheck.railway.app;*.up.railway.app
Database__UseInMemory=false

# Optional — tablo sayıları için GET /health/status (header: X-Monitoring-Key)
Monitoring__ApiKey=CHANGE-ME-MONITORING-SECRET

# Optional — LinkedIn Sign In (POST /LoginWithLinkedIn)
LinkedInAuth__ClientId=77zpy3yc04qs2c
LinkedInAuth__ClientSecret=YOUR_LINKEDIN_CLIENT_SECRET_FROM_DEVELOPER_PORTAL
LinkedInAuth__RedirectUri=https://cardenceapi.app/auth/linkedin/callback

# Password reset emails — SendGrid SMTP (https://app.sendgrid.com)
# 1. SendGrid → Settings → API Keys → Create API Key (Mail Send)
# 2. SendGrid → Settings → Sender Authentication → verify noreply@cardenceapi.app
Email__FromName=Cardence
Email__FromAddress=noreply@cardenceapi.app
Email__SmtpHost=smtp.sendgrid.net
Email__SmtpPort=587
Email__SmtpUsername=apikey
Email__SmtpPassword=SG.YOUR_SENDGRID_API_KEY
Email__UseSsl=true
PasswordReset__ResetBaseUrl=https://cardenceapi.app/auth/reset-password
PasswordReset__TokenLifetimeMinutes=30

# Push notifications (FCM) — Firebase service account JSON (tek satır)
# Yerel: backend/secrets/firebase-service-account.json + appsettings.Development.json
# Production: aşağıdaki komutla Railway'e set edin (backend/deploy/scripts/set-push-notifications-railway.sh)
# PushNotifications__ServiceAccountJson={"type":"service_account","project_id":"cardence-3cec8",...}
#
# Medya depolama — profil ve etkinlik fotoğrafları (Railway Volume)
ObjectStorage__Provider=local
ObjectStorage__LocalRootPath=/app/uploads
RAILWAY_RUN_UID=0
#
# Volume: cardence-volume → /app/uploads (cardence API servisi)
# Kurulum: backend/deploy/scripts/setup-uploads-volume-railway.sh
#
#   ObjectStorage__Provider=s3
#   ObjectStorage__Bucket=cardence-uploads
#   ObjectStorage__Endpoint=https://ACCOUNT_ID.r2.cloudflarestorage.com
#   ObjectStorage__Region=auto
#   ObjectStorage__AccessKeyId=...
#   ObjectStorage__SecretAccessKey=...
#
# ConnectionStrings__Default=Host=postgres.railway.internal;Port=5432;Database=railway;Username=postgres;Password=${{Postgres.PGPASSWORD}};SSL Mode=Require;Trust Server Certificate=true
#
# Option B: Railway postgres URI (app converts to Npgsql automatically)
# ConnectionStrings__Default=${{Postgres.DATABASE_URL}}
