# Railway — Cardence API environment variables
# Set these on the cardence API service (Root Directory: backend).
#
# PostgreSQL must be added as a separate Railway service first.
# See docs/deployment-cardenceapi.app.md → "PostgreSQL (Railway)".

# Required
ASPNETCORE_ENVIRONMENT=Production
Jwt__SigningKey=CHANGE-ME-MIN-32-CHARS-RANDOM-SECRET
Api__PublicBaseUrl=https://cardenceapi.app
AllowedHosts=cardenceapi.app;www.cardenceapi.app
Database__UseInMemory=false

# Option A (recommended): reference Postgres service variables in Railway UI
# Variable name:  ConnectionStrings__Default
# Variable value: ${{Postgres.DATABASE_PRIVATE_URL}}
#
# Replace "Postgres" with your PostgreSQL service name if different.

# Option B: Npgsql key=value string (from Postgres → Connect tab)
# ConnectionStrings__Default=Host=xxx.railway.internal;Port=5432;Database=railway;Username=postgres;Password=xxx;SSL Mode=Require

# Option C: Railway injects DATABASE_URL when you use "Add Reference" on Postgres vars
# The app also reads DATABASE_URL / DATABASE_PRIVATE_URL automatically.
